{
  "version": 1,
  "author": "Home IoT Project",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": { "env": "micropython-20231227-v1.22.0" }
    },
    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -160,
      "left": -220,
      "attrs": { "temperature": "28", "humidity": "65" }
    },
    {
      "type": "wokwi-photoresistor-sensor",
      "id": "ldr1",
      "top": -160,
      "left": -80,
      "attrs": { "value": "500" }
    },
    {
      "type": "wokwi-pir-motion-sensor",
      "id": "pir1",
      "top": -160,
      "left": 60,
      "attrs": {}
    },
    {
      "type": "wokwi-gas-sensor",
      "id": "mq1",
      "top": -160,
      "left": 220,
      "attrs": {}
    },
    {
      "type": "wokwi-rgb-led",
      "id": "rgb1",
      "top": 280,
      "left": -260,
      "attrs": {}
    },
    {
      "type": "wokwi-servo",
      "id": "servo1",
      "top": 280,
      "left": -120,
      "attrs": { "horn": "single" }
    },
    {
      "type": "wokwi-led",
      "id": "alarm1",
      "top": 280,
      "left": 60,
      "attrs": { "color": "red", "label": "ALARM" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_alarm",
      "top": 300,
      "left": 20,
      "attrs": { "value": "220" }
    },
    {
      "type": "board-ssd1306",
      "id": "oled1",
      "top": 280,
      "left": 160,
      "attrs": { "i2cAddress": "0x3c" }
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["dht1:VCC", "esp:3V3",   "red",   []],
    ["dht1:GND", "esp:GND.1", "black", []],
    ["dht1:SDA", "esp:4",     "green", []],

    ["ldr1:VCC", "esp:3V3",   "red",    []],
    ["ldr1:GND", "esp:GND.1", "black",  []],
    ["ldr1:AO",  "esp:34",    "yellow", []],

    ["pir1:POS", "esp:3V3",   "red",    []],
    ["pir1:GND", "esp:GND.1", "black",  []],
    ["pir1:OUT", "esp:35",    "orange", []],

    ["mq1:VCC",  "esp:3V3",   "red",    []],
    ["mq1:GND",  "esp:GND.1", "black",  []],
    ["mq1:AOUT", "esp:32",    "purple", []],

    ["esp:25",   "rgb1:R",    "red",   []],
    ["esp:26",   "rgb1:G",    "green", []],
    ["esp:27",   "rgb1:B",    "blue",  []],
    ["esp:GND.1","rgb1:COM",  "black", []],

    ["esp:18",   "servo1:PWM","orange", []],
    ["esp:3V3",  "servo1:V+", "red",    []],
    ["esp:GND.1","servo1:GND","black",  []],

    ["esp:23",   "r_alarm:1", "red",   []],
    ["r_alarm:2","alarm1:A",  "red",   []],
    ["esp:GND.1","alarm1:K",  "black", []],

    ["oled1:GND","esp:GND.2", "black",  []],
    ["oled1:VCC","esp:3V3",   "red",    []],
    ["oled1:SCL","esp:22",    "yellow", []],
    ["oled1:SDA","esp:21",    "blue",   []]
  ],
  "dependencies": {}
}