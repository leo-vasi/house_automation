    {
        "id": "get_last_reading",
        "type": "function",
        "z": "c1bce40c3c39a0ad",
        "name": "Pega ultima leitura",
        "func": "var d = global.get('last_reading') || {};\nvar now = new Date();\nvar dt = now.getFullYear()+'-'+(now.getMonth()+1).toString().padStart(2,'0')+'-'+now.getDate().toString().padStart(2,'0')+' '+now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0')+':'+now.getSeconds().toString().padStart(2,'0');\nmsg.payload = {\n  datetime:    dt,\n  temperatura: d.temperature || 0,\n  umidade:     d.humidity || 0,\n  ldr:         d.ldr || 0,\n  gas:         d.gas || 0,\n  movimento:   d.motion ? 'SIM' : 'NAO',\n  relay1:      d.relay1 ? 'ON' : 'OFF',\n  relay2:      d.relay2 ? 'ON' : 'OFF',\n  relay3:      d.relay3 ? 'ON' : 'OFF',\n  relay4:      d.relay4 ? 'ON' : 'OFF'\n};\nreturn msg;",
        "outputs": 1,
        "x": 710,
