    {
        "id": "save_last_reading",
        "type": "function",
        "z": "c1bce40c3c39a0ad",
        "name": "Salva ultima leitura",
        "func": "global.set('last_reading', msg.payload);\nreturn null;",
        "outputs": 1,
        "x": 910,
        "y": 120,
        "wires": [
            []
        ]
    },
    {
        "id": "split_sensors",
        "type": "function",
        "z": "c1bce40c3c39a0ad",
        "name": "Separa campos",
        "func": "var d = msg.payload;\nnode.send([\n  [{payload: d.temperature, timestamp: Date.now()}],\n  [{payload: d.humidity}],\n  [{payload: d.ldr}],\n  [{payload: d.gas}],\n  [{payload: d.motion ? 'SIM' : 'NAO'}],\n  [{payload: d.relay1 ? 'ON' : 'OFF'}],\n  [{payload: d.relay2 ? 'ON' : 'OFF'}],\n  [{payload: d.relay3 ? 'ON' : 'OFF'}],\n  [{payload: d.relay4 ? 'ON' : 'OFF'}],\n  [{payload: d.servo}]\n]);",
        "outputs": 10,
        "x": 860,
        "y": 320,
        "wires": [
            [
                "gauge_temp",
                "chart_temp"
            ],
            [
                "gauge_hum"
            ],
            [
                "gauge_ldr"
            ],
            [
                "gauge_gas"
            ],
            [
                "text_motion"
            ],
            [
                "text_r1"
            ],
            [
                "text_r2"
            ],
            [
                "text_r3"
            ],
            [
                "text_r4"
            ],
            [
                "gauge_servo"
            ]
        ]
    },
